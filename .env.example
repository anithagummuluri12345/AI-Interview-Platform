# =========================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================

# -------------------------------------------------------------------------
# APPLICATION GENERAL CONFIGURATION
# -------------------------------------------------------------------------
NODE_ENV=production
PORT=4000

# -------------------------------------------------------------------------
# BACKEND SERVICES CONFIGURATIONS (NestJS API)
# -------------------------------------------------------------------------

# Production PostgreSQL Database Connection
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For Railway, use the generated DATABASE_URL from your Postgres service connection.
DATABASE_URL=postgresql://postgres:secure_password@database-host:5432/ai_interview

# Upstash Redis Connection String (SSL Required for Cloud instances)
# Format: rediss://default:[token]@host.upstash.io:6379
REDIS_URL=rediss://default:your_upstash_token@your-redis-instance.upstash.io:6379

# JWT Secrets for Authentication (Generate strong random keys in production)
JWT_ACCESS_SECRET=your-production-jwt-access-secret-key-at-least-32-chars
JWT_REFRESH_SECRET=your-production-jwt-refresh-secret-key-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Gemini API Configurations
# Obtain your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest

# AI Operation Timeouts (in milliseconds)
AI_REPORT_TIMEOUT_MS=90000
AI_CODING_TIMEOUT_MS=90000

# -------------------------------------------------------------------------
# FRONTEND CONFIGURATIONS (Next.js App)
# -------------------------------------------------------------------------

# Public API URL pointing to the deployed backend URL (no trailing slash)
# Used by Vercel frontend build process
NEXT_PUBLIC_API_URL=https://your-backend-service.up.railway.app
